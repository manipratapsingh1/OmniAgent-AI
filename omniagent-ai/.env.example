# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
ENV=production
APP_NAME=OmniAgent AI
APP_VERSION=2.0.0
APP_DEBUG=false
APP_HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://omniagent:changeme@localhost:5432/omniagent
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# ============================================================================
# CACHE & SESSION - Redis
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_SOCKET_TIMEOUT=5

# ============================================================================
# VECTOR DATABASE - Chroma
# ============================================================================
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_TIMEOUT=10

# ============================================================================
# LARGE LANGUAGE MODEL - Ollama
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_FAST_MODEL=phi3:mini
OLLAMA_TIMEOUT=120

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440
API_KEY_EXPIRY_DAYS=90

# ============================================================================
# CORS - Cross-Origin Resource Sharing
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com
CORS_CREDENTIALS=true

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000
RESPONSE_CACHE_ENABLED=true
QUERY_CACHE_ENABLED=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# BACKGROUND JOBS - Celery (Optional)
# ============================================================================
ENABLE_CELERY=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# MEMORY SETTINGS
# ============================================================================
SHORT_TERM_MEMORY_TTL_SECONDS=3600
LONG_TERM_MEMORY_TTL_SECONDS=2592000
MAX_CONVERSATION_HISTORY=100

# ============================================================================
# RAG (RETRIEVAL AUGMENTED GENERATION)
# ============================================================================
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_RETRIEVAL_LIMIT=5
RAG_SIMILARITY_THRESHOLD=0.3
RAG_CACHE_ENABLED=true

# ============================================================================
# USER QUOTAS
# ============================================================================
DEFAULT_USER_QUOTA=1000
ADMIN_QUOTA=10000
QUOTA_RESET_DAY=1

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_ADMIN_API=true
ENABLE_API_KEYS=true
ENABLE_NOTIFICATIONS=true
ENABLE_AUDIT_LOG=true
ENABLE_SEARCH=true