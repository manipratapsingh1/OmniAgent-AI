# 🚀 OmniAgent Backend - Production Environment
# Use this for production deployments

APP_ENV=production
APP_DEBUG=false

# Security
SECRET_KEY=${SECRET_KEY}
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=${DATABASE_URL}
REDIS_URL=${REDIS_URL}

# CORS - Set your production domain
CORS_ORIGINS=${CORS_ORIGINS}

# LLM Provider
OLLAMA_BASE_URL=${OLLAMA_BASE_URL}
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_FAST_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text

# Timeouts
OLLAMA_EMBED_TIMEOUT=30
OLLAMA_GENERATE_TIMEOUT=60

# Vector Database
VECTOR_BACKEND=chroma
CHROMA_HOST=${CHROMA_HOST}
CHROMA_PORT=8001

# RAG Settings
MAX_DOCUMENT_SIZE_MB=10
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5

# Memory
SHORT_TERM_MEMORY_TTL=3600
LONG_TERM_MEMORY_LIMIT=1000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# API Keys
API_KEY_EXPIRY_DAYS=365

# Features
ENABLE_WEBSOCKETS=true
ENABLE_CELERY=true
CELERY_BROKER_URL=${REDIS_URL}/1
CELERY_RESULT_BACKEND=${REDIS_URL}/2

# Monitoring
ENABLE_SENTRY=true
SENTRY_DSN=${SENTRY_DSN}

# Feature Flags
ASSISTANT_ENABLED=true
