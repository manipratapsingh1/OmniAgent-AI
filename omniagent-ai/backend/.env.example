# 🚀 OmniAgent Backend - Environment Variables
# Copy this file to .env and fill in the required values

# ======= CRITICAL SETTINGS (MUST SET) =======
# Generate a 32+ character random secret key
SECRET_KEY=your-secret-key-change-me-to-something-random-and-long-at-least-32-chars

# PostgreSQL connection string
# Format: postgresql://username:password@localhost:5432/database_name
# For local development:
DATABASE_URL=postgresql://postgres:1234@localhost:5432/omniagent

# Redis connection (for caching and async tasks)
REDIS_URL=redis://localhost:6379/0

# ======= APPLICATION SETTINGS =======
APP_NAME=OmniAgent AI
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# JWT Configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ======= CORS SETTINGS =======
# Comma-separated list of allowed origins
# For production, specify exact origins
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ======= LLM PROVIDER SETTINGS =======
# Ollama (local LLM server)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_FAST_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text

# Timeouts (in seconds) - optimized for production
OLLAMA_EMBED_TIMEOUT=30
OLLAMA_GENERATE_TIMEOUT=60

# ======= VECTOR DATABASE =======
# Choose: "chroma" or "weaviate"
VECTOR_BACKEND=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ======= RAG SETTINGS =======
MAX_DOCUMENT_SIZE_MB=10
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5

# ======= MEMORY SETTINGS =======
SHORT_TERM_MEMORY_TTL=3600  # 1 hour in seconds
LONG_TERM_MEMORY_LIMIT=1000  # max stored memory entries

# ======= RATE LIMITING =======
RATE_LIMIT_PER_MINUTE=120

# ======= API KEY SETTINGS =======
API_KEY_EXPIRY_DAYS=365

# ======= OPTIONAL FEATURES =======
ENABLE_CELERY=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

ENABLE_WEBSOCKETS=true
WEBSOCKET_HEARTBEAT_INTERVAL=30

# ======= MONITORING & LOGGING =======
ENABLE_SENTRY=false
SENTRY_DSN=

# ======= FEATURE FLAGS =======
ASSISTANT_ENABLED=true

# ======= DATABASE POOL SETTINGS (Advanced) =======
# Recommended for production:
# - pool_size: 20 (connections to keep in pool)
# - max_overflow: 40 (additional connections when needed)
# - pool_timeout: 30 (wait time for available connection)
# These are automatically configured in code based on database type
