# OmniAgent AI - Environment Configuration

# ========== DATABASE ==========
DATABASE_URL=sqlite:///./omniai.db
# For PostgreSQL: postgresql://user:password@localhost:5432/omniai
# For production, use: postgresql+psycopg2://user:password@db.host:5432/omniai

# ========== API KEYS ==========
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your-google-custom-search-api-key
OPENWEATHER_API_KEY=your-openweather-api-key

# ========== SECURITY ==========
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== FRONTEND ==========
CORS_ORIGINS=http://localhost:3000,http://localhost,https://yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ========== LOGGING ==========
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ========== SERVER ==========
PORT=8000
WORKERS=4
ENVIRONMENT=development
# Options: development, staging, production

# ========== REDIS (Optional - for caching) ==========
REDIS_URL=redis://localhost:6379/0

# ========== VECTOR DB ==========
CHROMA_DB_PATH=./chroma_data
VECTOR_DB_TYPE=chroma
# Options: chroma, faiss, pinecone

# ========== FILE UPLOADS ==========
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ========== RATE LIMITING ==========
RATE_LIMIT_ENABLED=true
REQUESTS_PER_MINUTE=60

# ========== FEATURES ==========
ENABLE_RAG=true
ENABLE_STREAMING=true
ENABLE_MEMORY=true
ENABLE_TOOLS=true
ENABLE_TASK_AUTOMATION=true
